                    <auditRuleSet name="Effective Java" description="Audits from the book &apos;Effective Java&apos; by Joshua Bloch. These best practices from the book cover areas like coding style, exception usage, Javadoc conventions, naming, possible errors, and threading." locked="true" active="true" ignoreDisableDirectives="false" autoResolutionEnabled="false" maximumViolationCount="20000" maximumViolationCountByType="2000" maximumViolationCountInResource="200" maximumViolationCountByTypeInResource="20" resourceFilterEnabled="false">
                        <resourceFilter>
