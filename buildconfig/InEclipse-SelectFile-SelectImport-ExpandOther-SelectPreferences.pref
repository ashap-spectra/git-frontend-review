        #Wed Apr 13 13:58:21 MDT 2016
        com.instantiations.assist.eclipse.analysis.jUnitChecks.comment=Yep. --Rusty
        com.instantiations.assist.eclipse.audit.statementCreation.comment=Yes, due to RDMS pre-compiling &amp; caching PreparedStatement is an order of magnitude more efficient than Statement. You should not use Statement unless you can't get an SQL created without it, but there will be times when this is exactly the case. So will not enforce it. --Rusty
        com.instantiations.assist.eclipse.audit.numericLiterals.severity=0
        com.instantiations.assist.eclipse.analysis.appletFieldSecurity.comment=Turn this on so we'll know the first time it happens should we begin to develop Applets--we'll decided what to do then. --Rusty 2007/05/09
