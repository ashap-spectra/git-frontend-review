                    <auditRuleSet name="Spectra Logic Corporation" locked="false" active="true" ignoreDisableDirectives="true" autoResolutionEnabled="false" maximumViolationCount="20000" maximumViolationCountByType="2000" maximumViolationCountInResource="200" maximumViolationCountByTypeInResource="50" resourceFilterEnabled="false" default="true">
