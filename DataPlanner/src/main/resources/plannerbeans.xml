<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans xmlschema/spring-beans.xsd">

    <bean id="propertyPlaceholderConfigurer" class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
        <property name="location">
            <value>file:/etc/spectralogic/tapesystem.properties</value>
        </property>
        <property name="properties">
            <props>
                <prop key="com.spectralogic.s3.dataplanner.inactivitylength">60000</prop>
            </props>
        </property>
    </bean>
    
    <bean id="DataSource" class="com.spectralogic.util.db.manager.postgres.PostgresDataSource">
        <constructor-arg value="${com.spectralogic.em.jiveresource.host}" />
        <constructor-arg value="${com.spectralogic.em.jiveresource.schema}" />
        <constructor-arg value="${com.spectralogic.em.jiveresource.username}" />
        <constructor-arg value="${com.spectralogic.em.jiveresource.password}" />
    </bean>
    
    <bean id="DataPlanner" class="com.spectralogic.s3.dataplanner.DataPlanner" destroy-method="shutdown" scope="singleton">
        <constructor-arg ref="DataSource" />
    </bean>
    
</beans>
