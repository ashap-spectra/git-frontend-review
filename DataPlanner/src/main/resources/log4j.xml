<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">

      <appender name="FILE" class="org.apache.log4j.RollingFileAppender">    
      <param name="File" value="/var/log/dataplanner-main.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="8" />
      <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="BACKEND_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-backend.log" />
        <param name="MaxFileSize" value="10MB" />
        <param name="MaxBackupIndex" value="8" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="WARN_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-alert.log" />
        <param name="MaxFileSize" value="10MB" />
        <param name="MaxBackupIndex" value="4" />
        <param name="Threshold" value="WARN" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="RPC_CLIENT_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-rpcclient.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="4" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="RPC_SERVER_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-rpcserver.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="4" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="TARGET_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-target.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="8" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="NOTIFICATIONS_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-notifications.log" />
        <param name="MaxFileSize" value="10MB" />
        <param name="MaxBackupIndex" value="1" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="CPU_HOG_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-cpuhog.log" />
        <param name="MaxFileSize" value="10MB" />
        <param name="MaxBackupIndex" value="1" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="SQL_HOG_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-dbhog.log" />
        <param name="MaxFileSize" value="10MB" />
        <param name="MaxBackupIndex" value="1" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="SQL_SQL_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/dataplanner-dbsql.log" />
        <param name="MaxFileSize" value="10MB" />
        <param name="MaxBackupIndex" value="1" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <!-- Suppress success logging from InteractiveAuthenticationSuccessEvent -->
    <logger name="org.springframework.security">
        <level value="ERROR"/>
    </logger>

    <logger name="org.apache">
        <level value="WARN"/>
    </logger>

    <logger name="org.dbunit">
        <level value="WARN"/>
    </logger>

    <logger name="org.springframework">
        <level value="WARN"/>
    </logger>
   
    <logger name="org.appfuse">
        <level value="INFO"/>
    </logger>

    <logger name="org.appfuse.tool">
        <level value="INFO"/>
    </logger>
    
    <logger name="com.spectralogic">
        <level value="INFO"/>
    </logger>
    
    <logger name="com.spectralogic.s3.dataplanner.backend">
        <level value="INFO"/>
        <appender-ref ref="BACKEND_FILE"/>
    </logger>
    
    <logger name="com.spectralogic.ds3client" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="TARGET_FILE"/>
    </logger>
    
    <logger name="org.apache.http.wire" additivity="false">
        <level value="WARN"/>
        <appender-ref ref="TARGET_FILE"/>
    </logger>
    
    <logger name="com.amazonaws" additivity="false">
        <level value="WARN"/>
        <appender-ref ref="TARGET_FILE"/>
    </logger>
    
    <logger name="com.spectralogic.util.net.rpc.frmwrk.RpcLogger.Server" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="RPC_SERVER_FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </logger>
    <logger name="com.spectralogic.util.net.rpc.frmwrk.RpcLogger.Client" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="RPC_CLIENT_FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </logger>
    <logger name="com.spectralogic.s3.target.TargetLogger" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="TARGET_FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </logger>
    <logger name="com.spectralogic.util.notification.dispatch.bean.HttpNotificationEventDispatcher" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="NOTIFICATIONS_FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </logger>
    
    <logger name="com.spectralogic.util.healthmon.CpuHogDetector" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="CPU_HOG_FILE"/>
    </logger>
    <logger name="com.spectralogic.util.healthmon.CpuHogListenerImpl" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="CPU_HOG_FILE"/>
    </logger>
    
    <logger name="SpectraDbHogLog" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="SQL_HOG_FILE"/>
    </logger>
    
    <logger name="SpectraDbSqlLog" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="SQL_SQL_FILE"/>
    </logger>

    <root>
        <level value="WARN"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </root>

</log4j:configuration>
