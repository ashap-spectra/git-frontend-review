# STAGE 1: Build Stage (Gradle)
# Using a Gradle image to resolve all external dependencies and build internal modules
FROM gradle:8.5-jdk21 AS build-stage

WORKDIR /home/gradle/project
# Copy all project files into the build container
COPY --chown=gradle:gradle . .

# 1. Build the project modules (DataPlanner, util, common, target)
# 2. Use a custom task or script logic to collect all external JARs into a single 'lib-all' folder
RUN ./gradlew :DataPlanner:assemble :util:assemble :common:assemble :target:assemble --no-daemon && \
    mkdir -p /home/gradle/lib-all && \
    # Helper: Find all runtime dependency JARs from Gradle cache
    find /home/gradle/.gradle/caches/modules-2/files-2.1 -name "*.jar" -exec cp {} /home/gradle/lib-all/ \; && \

    if [ -d "lib" ]; then cp lib/*.jar /home/gradle/lib-all/; fi

# STAGE 2: Final Runtime Image
FROM tomcat:9.0-jdk21

# Add the 'contrib' and 'non-free' repositories for specific Linux tools
RUN sed -i 's/main/main contrib non-free/g' /etc/apt/sources.list

RUN apt-get update && \
    apt-get install -y vim postgresql-client zfsutils-linux && \
    rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y ntpdate

# Set environment variables
ENV DATAPLANNER_HOME="/usr/local/bluestorm/frontend/dataplanner"
ENV DATAPLANNER_FILE="DataPlanner-0.0.4-SNAPSHOT.jar"
ENV DATAPLANNER_PATH="${DATAPLANNER_HOME}/bin/${DATAPLANNER_FILE}"
ENV dataplanner_out_log="/var/log/dataplanner-startup.log"

# Create necessary directories
RUN mkdir -p ${DATAPLANNER_HOME}/bin/lib /var/log /app /etc/spectralogic /etc/spectra && \
    chmod 777 /var/log

# --- COPY FROM BUILD STAGE ---

# 1. Copy the External Libraries (Azure, AWS, Awaitility, etc.) resolved by Gradle
COPY --from=build-stage /home/gradle/lib-all/ ${DATAPLANNER_HOME}/bin/lib/

# 2. Copy Internal Module JARs built during the build stage
COPY --from=build-stage /home/gradle/project/DataPlanner/build/libs/${DATAPLANNER_FILE} ${DATAPLANNER_HOME}/bin/
COPY --from=build-stage /home/gradle/project/util/build/libs/util-*.jar ${DATAPLANNER_HOME}/bin/lib/
COPY --from=build-stage /home/gradle/project/common/build/libs/common-*.jar ${DATAPLANNER_HOME}/bin/lib/
COPY --from=build-stage /home/gradle/project/target/build/libs/target-*.jar ${DATAPLANNER_HOME}/bin/lib/

# --- COPY LOCAL CONFIGS ---
COPY docker/entrypoint-dataplanner.sh /app/entrypoint.sh
COPY docker/tapesystem.properties /etc/spectralogic/
COPY DataPlanner/src/test/resources/etc/spectra/serial_number /etc/spectra/
COPY DataPlanner/src/test/resources/etc/spectra/pf-s3port.conf /etc/spectra/
COPY docker/simulator_data /etc/spectra/
COPY docker/version.dataplanner.conf /etc/version.conf
COPY DataPlanner/src/main/resources/log4j.xml /app/log4j.xml
COPY docker/entrypoint-time-sync.sh /usr/local/bin/entrypoint-time-sync.sh
RUN chmod +x /usr/local/bin/entrypoint-time-sync.sh

RUN chmod +x /app/entrypoint.sh ${DATAPLANNER_HOME}/bin/${DATAPLANNER_FILE}

# Set working directory
WORKDIR ${DATAPLANNER_HOME}/bin/

# Start dataplanner using the entrypoint script
ENTRYPOINT ["/usr/local/bin/entrypoint-time-sync.sh","/app/entrypoint.sh"]