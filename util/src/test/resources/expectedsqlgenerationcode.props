expected.0=CREATE TYPE mockdomain.teacher_type AS ENUM ();

expected.1=CREATE TABLE mockdomain.principal (\
   id                   uuid       NOT NULL,\
   name                 varchar    NOT NULL,\
   type                 mockdomain.teacher_type NOT NULL,\
\
   PRIMARY KEY (id)\
);

expected.2=CREATE TABLE mockdomain.county (\
   id                   uuid       NOT NULL,\
   name                 varchar    NOT NULL,\
   population           bigint     NOT NULL,\
\
   PRIMARY KEY (id),\
   UNIQUE (name)\
);

expected.3=CREATE TYPE mockdomain.school_type AS ENUM ();

expected.4=CREATE TABLE mockdomain.school (\
   active               boolean    NOT NULL,\
   address              varchar    NULL,\
   county_id            uuid       NULL REFERENCES mockdomain.county ON UPDATE CASCADE,\
   id                   uuid       NOT NULL,\
   name                 varchar    NOT NULL,\
   type                 mockdomain.school_type NOT NULL,\
\
   PRIMARY KEY (id)\
);

expected.5=CREATE TABLE mockdomain.principal_school (\
   id                   uuid       NOT NULL,\
   principal_id         uuid       NOT NULL REFERENCES mockdomain.principal ON UPDATE CASCADE,\
   school_id            uuid       NOT NULL REFERENCES mockdomain.school ON UPDATE CASCADE,\
\
   PRIMARY KEY (id),\
   UNIQUE (principal_id, school_id)\
);

expected.6=CREATE TABLE mockdomain.teacher (\
   comments             varchar    NULL,\
   date_of_birth        timestamp without time zone NOT NULL,\
   id                   uuid       NOT NULL,\
   name                 varchar    NOT NULL,\
   password             varchar    NULL,\
   ssn                  varchar    NULL,\
   type                 mockdomain.teacher_type NOT NULL,\
   warnings_issued      integer    NOT NULL,\
   years_of_service     integer    NOT NULL,\
\
   PRIMARY KEY (id),\
   UNIQUE (date_of_birth, name),\
   UNIQUE (ssn)\
);

expected.7=CREATE TABLE mockdomain.teacher_school (\
   id                   uuid       NOT NULL,\
   school_id            uuid       NOT NULL REFERENCES mockdomain.school ON UPDATE CASCADE,\
   teacher_id           uuid       NOT NULL REFERENCES mockdomain.teacher ON UPDATE CASCADE ON DELETE CASCADE,\
\
   PRIMARY KEY (id),\
   UNIQUE (school_id, teacher_id)\
);

expected.8=CREATE INDEX ON mockdomain.extremely_long_bean_exceeding_postgres_maximum_character_limit (some_long_property_name);

expected.max=8