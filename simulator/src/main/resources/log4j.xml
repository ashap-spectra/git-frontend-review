<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">

	<appender name="FILE" class="org.apache.log4j.RollingFileAppender">    
    	<param name="File" value="/var/log/simulator-main.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="4" />
    	<layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="WARN_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/simulator-alert.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="4" />
        <param name="Threshold" value="WARN" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="RPC_SERVER_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/simulator-rpc.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="4" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <appender name="CPU_HOG_FILE" class="org.apache.log4j.RollingFileAppender">    
        <param name="File" value="/var/log/simulator-cpu.log" />
        <param name="MaxFileSize" value="20MB" />
        <param name="MaxBackupIndex" value="4" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                value="%p %d{MMM dd HH:mm:ss,SSS} [%t] | %m  (%C{1}.%M:%L)%n"/>
        </layout>
    </appender>

    <!-- Suppress success logging from InteractiveAuthenticationSuccessEvent -->
    <logger name="org.springframework.security">
        <level value="ERROR"/>
    </logger>

    <logger name="org.apache">
        <level value="WARN"/>
    </logger>

    <logger name="org.dbunit">
        <level value="WARN"/>
    </logger>

    <logger name="org.springframework">
        <level value="WARN"/>
    </logger>
   
    <logger name="org.appfuse">
        <level value="INFO"/>
    </logger>

    <logger name="org.appfuse.tool">
        <level value="INFO"/>
    </logger>
    
    <logger name="com.spectralogic">
        <level value="INFO"/>
    </logger>
    
    <logger name="com.spectralogic.util.net.rpc.frmwrk.RpcLogger" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="RPC_SERVER_FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </logger>
    
    <logger name="com.spectralogic.util.healthmon.CpuHogDetector" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="CPU_HOG_FILE"/>
    </logger>
    <logger name="com.spectralogic.util.healthmon.CpuHogListenerImpl" additivity="false">
        <level value="INFO"/>
        <appender-ref ref="CPU_HOG_FILE"/>
    </logger>

    <root>
        <level value="WARN"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="WARN_FILE"/>
    </root>

</log4j:configuration>
