<web-app version="2.4" xmlns="http://java.sun.com/xml/ns/j2ee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
    
    <context-param>
        <param-name>contextConfigLocation</param-name>
        <param-value>/WEB-INF/applicationContext.xml</param-value>
    </context-param>

    <listener>
        <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
    </listener>

    <filter>
        <!-- Ensure all inputs/request params are parsed/interpreted as UTF-8 encoded. -->
        <!-- https://wiki.apache.org/tomcat/FAQ/CharacterEncoding -->
        <!-- https://tomcat.apache.org/tomcat-5.5-doc/config/filter.html -->

        <filter-name>CharEncodeFilter</filter-name>
        <filter-class>
             org.apache.catalina.filters.SetCharacterEncodingFilter
        </filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>true</param-value> <!-- Ignore encoding values sent in requests. -->
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>CharEncodeFilter</filter-name>
        <url-pattern>/*</url-pattern> <!-- Apply this filter to every incoming
                                           request serviced by this web app. -->
    </filter-mapping>

    <!--  This system uses the spring controller framework -->
    <servlet>
        <servlet-name>dispatcher</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    
    <servlet>
        <servlet-name>dataServlet</servlet-name>
        <servlet-class>com.spectralogic.s3.server.servlet.DataServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>beanServlet</servlet-name>
        <servlet-class>com.spectralogic.s3.server.servlet.BeanServlet</servlet-class>
    </servlet>
        
    <servlet-mapping>
        <servlet-name>dispatcher</servlet-name>
        <url-pattern>/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>dataServlet</servlet-name>
        <url-pattern>/dataServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>beanServlet</servlet-name>
        <url-pattern>/beanServlet</url-pattern>
    </servlet-mapping>
    
    <session-config>
        <session-timeout>10</session-timeout>
    </session-config>
   
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/error.jsp</location>
      </error-page>
      <error-page>
        <error-code>400</error-code>
           <location>/WEB-INF/jsp/error.jsp</location>
      </error-page>
      <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/WEB-INF/jsp/error.jsp</location>
      </error-page>
</web-app>
